# ===================================================
# AI Exclude – Antigravity / Cursor ignore file
# Các thư mục/file này sẽ KHÔNG được AI tìm kiếm
# ===================================================

# --- Dependencies & build output ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
backend/.venv/
backend/__pycache__/
**/__pycache__/
**/*.pyc

# --- Static uploads (ảnh/file người dùng upload) ---
backend/static/
backend/static/thumbs/

# --- Logs ---
*.log
backend/logs/

# --- Môi trường & bí mật ---
.env
.env.*
*.pem
*.key

# --- IDE & hệ thống ---
.git/
.vscode/
.idea/
*.DS_Store
Thumbs.db

# --- Tài liệu lưu trữ cũ (không dùng production) ---
main-be/
archive/
temp/
docs/
scripts/tools/
